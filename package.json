{
  "name": "totp",
  "main": "expo-router/entry",
  "version": "1.0.0-alpha2",
  "homepage": "https://github.com/gccody/DUALL",
  "scripts": {
    "start": "bunx expo start",
    "start:remote": "bunx expo start --tunnel",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "bunx expo run:android",
    "build:dev:android": "EAS_SKIP_AUTO_FINGERPRINT=1 bunx eas-cli@latest build --platform android --profile development",
    "build:dev:ios": "EAS_SKIP_AUTO_FINGERPRINT=1 bunx eas-cli@latest build --platform ios --profile development",
    "build:dev": "EAS_SKIP_AUTO_FINGERPRINT=1 bunx eas-cli@latest build --profile development",
    "ios": "bunx expo run:ios",
    "web": "bunx expo start --web",
    "test": "jest --runInBand --passWithNoTests",
    "lint": "bunx expo lint",
    "fetch:data": "bun run scripts/scrapeTotp.ts",
    "push:dev": "git checkout development && git reset --hard main && git push origin development --force"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
